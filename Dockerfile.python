ARG url=localhost:30500/pytrtllm:put-your-version
FROM $url AS pytrtllm-builder

COPY python.patch /app/tensorrt_llm/python.patch
RUN patch -p1 -i/app/tensorrt_llm/python.patch -d/usr/local/lib/python3.12/dist-packages
#RUN pip install git+https://github.com/Dao-AILab/fast-hadamard-transform.git

# Prebuilt KV local indexer extension (no Rust toolchain here). The .py changes
# ride in via python.patch above; this native module is a separate wheel that
# build_python_changes.sh fetches from the deepinfra/kv-local-indexer GitHub
# release into ./wheels before this build. Tolerant of an absent wheel so images
# that don't need recovery still build.
COPY wheels/ /tmp/kv_local_indexer_wheels/
RUN if ls /tmp/kv_local_indexer_wheels/*.whl >/dev/null 2>&1; then \
        pip install --no-deps --no-index \
            --find-links=/tmp/kv_local_indexer_wheels kv-local-indexer && \
        python3.12 -c "import kv_local_indexer; print('kv_local_indexer OK')"; \
    else \
        echo "kv_local_indexer wheel not present in ./wheels; enable_local_indexer + /kv_recover will be unavailable"; \
    fi

ENTRYPOINT ["/bin/bash", "-c", "exec \"$@\"", "--", "/usr/local/bin/trtllm-serve"]
